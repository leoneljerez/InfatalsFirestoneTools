@using BreakEternity
@using InfatalsFirestoneTools.Models
@using InfatalsFirestoneTools.Resources
@using System.Text.RegularExpressions
@using System.Globalization
@inject IStringLocalizer<LanguageResource> L

<BbCard Class="@($"w-2xs shrink-0 overflow-hidden {GetRarityClasses()}")">

    @* Header *@
    <BbCardHeader Class="items-center text-center">
        <picture>
            <source type="image/jxl" srcset="@($"{Machine.Image}.jxl")" />
            <source type="image/avif" srcset="@($"{Machine.Image}.avif")" />
            <source type="image/webp" srcset="@($"{Machine.Image}.webp")" />
            <img src="@($"{Machine.Image}.png")" alt="@L[Machine.Name]" class="w-20 h-20 object-scale-down rounded-lg mx-auto" />
        </picture>

        <BbCardTitle Class="text-sm font-semibold text-center mt-1">
            @L[Machine.Name]
        </BbCardTitle>

        <BbCardDescription Class="@($"text-xs text-center px-2 py-0.5 rounded-full {GetBadgeClasses()}")">
            @L["LevelShort"] @Machine.Level · @L[@Machine.Rarity.ToString()]
        </BbCardDescription>

        @if (_rank is not null)
        {
            <div class="flex items-center justify-center gap-0.5 mt-2" title="@L[_rank.DisplayText]">
                @for (int i = 0; i < _rank.Count; i++)
                {
                    <picture>
                        <source type="image/jxl" srcset="@($"{_rank.ImageBasePath}.jxl")" />
                        <source type="image/avif" srcset="@($"{_rank.ImageBasePath}.avif")" />
                        <source type="image/webp" srcset="@($"{_rank.ImageBasePath}.webp")" />
                        <img src="@($"{_rank.ImageBasePath}.png")" alt="@L[_rank.DisplayText]" class="w-5 h-5 object-contain" />
                    </picture>
                }
            </div>
        }
    </BbCardHeader>

    @* Stats: icon on top, value below, three equal columns *@
    <BbCardContent>
        <BbCard Class="bg-muted/25 border-0 shadow-none">
            <BbCardContent Class="p-2">
                <div class="grid grid-cols-3 divide-x divide-border">

                    <div class="flex flex-col items-center gap-1 px-2">
                        <picture>
                            <source type="image/jxl" srcset="img/ui/wmDamagex128.jxl" />
                            <source type="image/avif" srcset="img/ui/wmDamagex128.avif" />
                            <source type="image/webp" srcset="img/ui/wmDamagex128.webp" />
                            <img src="img/ui/wmDamagex128.png" alt="@L["Damage"]" class="w-5 h-5 object-contain" title="@L["Damage"]"/>
                        </picture>
                        <span class="font-mono text-xs text-center leading-tight break-all">
                            @FormatStat(ActiveStats.Damage)
                        </span>
                    </div>

                    <div class="flex flex-col items-center gap-1 px-2">
                        <picture>
                            <source type="image/jxl" srcset="img/ui/wmHealthx128.jxl" />
                            <source type="image/avif" srcset="img/ui/wmHealthx128.avif" />
                            <source type="image/webp" srcset="img/ui/wmHealthx128.webp" />
                            <img src="img/ui/wmHealthx128.png" alt="@L["Health"]" class="w-5 h-5 object-contain" title="@L["Health"]"/>
                        </picture>
                        <span class="font-mono text-xs text-center leading-tight break-all">
                            @FormatStat(ActiveStats.Health)
                        </span>
                    </div>

                    <div class="flex flex-col items-center gap-1 px-2">
                        <picture>
                            <source type="image/jxl" srcset="img/ui/wmArmorx128.jxl" />
                            <source type="image/avif" srcset="img/ui/wmArmorx128.avif" />
                            <source type="image/webp" srcset="img/ui/wmArmorx128.webp" />
                            <img src="img/ui/wmArmorx128.png" alt="@L["Armor"]" class="w-5 h-5 object-contain" title="@L["Armor"]"/>
                        </picture>
                        <span class="font-mono text-xs text-center leading-tight break-all">
                            @FormatStat(ActiveStats.Armor)
                        </span>
                    </div>

                </div>
            </BbCardContent>
        </BbCard>
    </BbCardContent>

    @* Crew *@
    <BbCardFooter Class="flex-col gap-2 pt-0">
        @if (Machine.Crew.Any())
        {
            <BbSeparator Class="w-full" />
            <div class="flex flex-wrap justify-center gap-1.5 pt-1">
                @foreach (var hero in Machine.Crew)
                {
                    <BbHoverCard>
                        <BbHoverCardTrigger>
                            <BbButton Variant="ButtonVariant.Ghost" Class="p-0 h-auto rounded border border-border focus-visible:ring-1">
                                <picture>
                                    <source type="image/jxl" srcset="@($"{hero.Image}.jxl")" />
                                    <source type="image/avif" srcset="@($"{hero.Image}.avif")" />
                                    <source type="image/webp" srcset="@($"{hero.Image}.webp")" />
                                    <img src="@($"{hero.Image}.png")" alt="@L[hero.Name]" class="w-8 h-8 object-scale-down rounded" />
                                </picture>
                            </BbButton>
                        </BbHoverCardTrigger>

                        <BbHoverCardContent Class="w-3xs p-0">
                            <BbCard Class="border-0 shadow-none">
                                <BbCardHeader Class="flex-row items-center gap-2 pb-2">
                                    <picture>
                                        <source type="image/jxl" srcset="@($"{hero.Image}.jxl")" />
                                        <source type="image/avif" srcset="@($"{hero.Image}.avif")" />
                                        <source type="image/webp" srcset="@($"{hero.Image}.webp")" />
                                        <img src="@($"{hero.Image}.png")" alt="@L[hero.Name]" class="w-10 h-10 object-scale-down rounded shrink-0" />
                                    </picture>
                                    <BbCardTitle Class="text-sm leading-tight">@L[hero.Name]</BbCardTitle>
                                </BbCardHeader>

                                <BbSeparator />

                                @* Hero stat bonuses: icon top, value bottom, 3 cols *@
                                <BbCardContent Class="pt-2">
                                    <div class="grid grid-cols-3 divide-x divide-border">

                                        <div class="flex flex-col items-center gap-1 px-1.5">
                                            <picture>
                                                <source type="image/jxl" srcset="img/ui/wmDamagex128.jxl" />
                                                <source type="image/avif" srcset="img/ui/wmDamagex128.avif" />
                                                <source type="image/webp" srcset="img/ui/wmDamagex128.webp" />
                                                <img src="img/ui/wmDamagex128.png" alt="@L["Damage"]" title="@L["Damage"]" class="w-4 h-4 object-contain" />
                                            </picture>
                                            <span class="font-mono text-xs text-center">
                                                @(hero.DamagePercentage > 0 ? $"{hero.DamagePercentage}" : "—")
                                            </span>
                                        </div>

                                        <div class="flex flex-col items-center gap-1 px-1.5">
                                            <picture>
                                                <source type="image/jxl" srcset="img/ui/wmHealthx128.jxl" />
                                                <source type="image/avif" srcset="img/ui/wmHealthx128.avif" />
                                                <source type="image/webp" srcset="img/ui/wmHealthx128.webp" />
                                                <img src="img/ui/wmHealthx128.png" alt="@L["Health"]" title="@L["Health"]" class="w-4 h-4 object-contain" />
                                            </picture>
                                            <span class="font-mono text-xs text-center">
                                                @(hero.HealthPercentage > 0 ? $"{hero.HealthPercentage}" : "—")
                                            </span>
                                        </div>

                                        <div class="flex flex-col items-center gap-1 px-1.5">
                                            <picture>
                                                <source type="image/jxl" srcset="img/ui/wmArmorx128.jxl" />
                                                <source type="image/avif" srcset="img/ui/wmArmorx128.avif" />
                                                <source type="image/webp" srcset="img/ui/wmArmorx128.webp" />
                                                <img src="img/ui/wmArmorx128.png" alt="@L["Armor"]" title="@L["Armor"]" class="w-4 h-4 object-contain" />
                                            </picture>
                                            <span class="font-mono text-xs text-center">
                                                @(hero.ArmorPercentage > 0 ? $"{hero.ArmorPercentage}" : "—")
                                            </span>
                                        </div>

                                    </div>
                                </BbCardContent>
                            </BbCard>
                        </BbHoverCardContent>
                    </BbHoverCard>
                }
            </div>
        }
        else
        {
            <BbSeparator Class="w-full" />
            <p class="text-xs text-muted-foreground italic text-center pt-1">@L["NoCrewAssigned"]</p>
        }
    </BbCardFooter>

</BbCard>

@code {
    [Parameter, EditorRequired] public ComputedMachine Machine { get; set; } = null!;
    [Parameter, EditorRequired] public string StatsMode { get; set; } = "battle";

    private MachineRank? _rank;

    private MachineStats ActiveStats =>
        StatsMode == "arena" ? Machine.ArenaStats : Machine.BattleStats;

    protected override void OnParametersSet()
    {
        _rank = MachineRank.FromLevel(Machine.Level);
    }

    private static string FormatStat(BigDouble value)
    {
        var returnedString = value.toExponential(2);

        // removes the + and 0's from the beginning of a number like 1.1e+01 > 1.1e1
        var cleanedString = Regex.Replace(returnedString, @"([eE])\+?(-?)0+(\d+)", "$1$2$3");

        // uses , or . depending on the culture
        var localSeparator = CultureInfo.CurrentCulture.NumberFormat.NumberDecimalSeparator;

        return cleanedString.Replace(".", localSeparator);
    }

    private string GetRarityClasses() => Machine.Rarity switch
    {
        MachineRarity.Common => "border-gray-400/30 hover:scale-[1.02] transition-transform",
        MachineRarity.Uncommon => "border-green-500/40 shadow-md shadow-green-500/10 hover:scale-[1.02] transition-transform",
        MachineRarity.Rare => "border-blue-500/50 shadow-lg shadow-blue-500/20 hover:scale-[1.02] transition-transform",
        MachineRarity.Epic => "border-purple-500/50 shadow-lg shadow-purple-500/30 hover:scale-[1.02] transition-transform",
        MachineRarity.Legendary => "border-yellow-500/50 shadow-lg shadow-yellow-500/30 hover:scale-[1.02] transition-transform",
        MachineRarity.Mythic => "border-pink-500/50 shadow-lg shadow-pink-500/30 hover:scale-[1.02] transition-transform",
        MachineRarity.Titan => "border-red-500/50 shadow-lg shadow-red-500/30 hover:scale-[1.02] transition-transform",
        MachineRarity.Angel => "border-cyan-500/50 shadow-lg shadow-cyan-500/30 hover:scale-[1.02] transition-transform",
        MachineRarity.Celestial => "border-white/50 shadow-lg shadow-white/30 hover:scale-[1.02] transition-transform",
        _ => "border-muted hover:scale-[1.02] transition-transform",
    };

    private string GetBadgeClasses() => Machine.Rarity switch
    {
        MachineRarity.Common => "bg-gray-400/10 border border-gray-400/20",
        MachineRarity.Uncommon => "bg-green-500/10 border border-green-500/20",
        MachineRarity.Rare => "bg-blue-500/10 border border-blue-500/20",
        MachineRarity.Epic => "bg-purple-500/10 border border-purple-500/20",
        MachineRarity.Legendary => "bg-yellow-400/10 border border-yellow-400/20",
        MachineRarity.Mythic => "bg-pink-500/10 border border-pink-500/20",
        MachineRarity.Titan => "bg-red-500/10 border border-red-500/20",
        MachineRarity.Angel => "bg-cyan-500/10 border border-cyan-500/20",
        MachineRarity.Celestial => "bg-white/10 border border-white/20",
        _ => "bg-muted/50",
    };
}