@using InfatalsFirestoneTools.Models
@using InfatalsFirestoneTools.Services
@using InfatalsFirestoneTools.Resources
@inject MachineService MachineService
@inject IStringLocalizer<LanguageResource> L

<div class="grid gap-4">
    <BbCard Class="bg-primary/5 border-primary/20">
        <BbCardHeader>
            <BbCardTitle>@L["GlobalBonuses"]</BbCardTitle>
        </BbCardHeader>
        <BbCardContent Class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-2">
                <BbLabel>@L["EngineerLevel"]</BbLabel>
                <BbNumericInput TValue="int" Min="0" Step="1" AllowNegative="false" ShowButtons="true"
                                Value="@Data.EngineerLevel"
                                ValueChanged="async v => { Data.EngineerLevel = v; await OnChanged.InvokeAsync(); }"
                                DebounceInterval="500" Class="w-full" />
            </div>
            <div class="space-y-2">
                <BbLabel>@L["ScarabLevel"]</BbLabel>
                <BbNumericInput TValue="int" Min="0" Step="1" AllowNegative="false" ShowButtons="true"
                                Value="@Data.ScarabLevel"
                                ValueChanged="async v => { Data.ScarabLevel = v; await OnChanged.InvokeAsync(); }"
                                DebounceInterval="500" Class="w-full" />
            </div>
            <div class="sm:col-span-2 space-y-2">
                <BbLabel>@L["ChaosRiftRank"]</BbLabel>
                <BbSelect TValue="ChaosRiftRank" Value="@Data.ChaosRiftRank"
                          ValueChanged="async v => { Data.ChaosRiftRank = v; await OnChanged.InvokeAsync(); }"
                          Class="w-full">
                    <BbSelectTrigger Class="w-full">
                        <BbSelectValue Placeholder="@L["SelectRiftRank"]" />
                    </BbSelectTrigger>
                    <BbSelectContent>
                        @foreach (var rank in Enum.GetValues<ChaosRiftRank>())
                        {
                            <BbSelectItem Value="@rank" Text="@L[rank.ToString()]">@L[rank.ToString()]</BbSelectItem>
                        }
                    </BbSelectContent>
                </BbSelect>
            </div>
        </BbCardContent>
    </BbCard>

    <div class="flex items-center gap-1 rounded-lg border bg-muted p-1 w-fit">
        <BbToggleGroup TValue="string" @bind-Value="_viewMode" Type="ToggleGroupType.Single">
            <BbToggleGroupItem Value="@("detail")">
                <LucideIcon Name="layout-panel-left" Size="14" Class="mr-1.5" />
                @L["Detail"]
            </BbToggleGroupItem>
            <BbToggleGroupItem Value="@("bulk")">
                <LucideIcon Name="table" Size="14" Class="mr-1.5" />
                @L["BulkEdit"]
            </BbToggleGroupItem>
        </BbToggleGroup>
    </div>

    @if (_viewMode == "detail")
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <div class="lg:col-span-1">
                <BbCard>
                    <BbCardHeader>
                        <BbCardTitle>@L["MachineList"]</BbCardTitle>
                    </BbCardHeader>
                    <BbCardContent Class="p-0">
                        <div class="p-3 border-b space-y-2">
                            <BbInput Placeholder="@L["Search"]" Value="@_search" class="w-full"
                                     @oninput="e => SetSearch(e.Value?.ToString() ?? string.Empty)" />
                            <div class="flex gap-2">
                                <BbSelect TValue="SortOptionsMachine" Value="@_detailSort"
                                          ValueChanged="SetDetailSort" Class="flex-1">
                                    <BbSelectTrigger Class="h-8 text-xs flex-1">
                                        <BbSelectValue Placeholder="@L["SortBy"]" />
                                    </BbSelectTrigger>
                                    <BbSelectContent>
                                        @foreach (var opt in Enum.GetValues<SortOptionsMachine>())
                                        {
                                            <BbSelectItem Value="@opt" Text="@L[opt.ToString()]">@L[opt.ToString()]</BbSelectItem>
                                        }
                                    </BbSelectContent>
                                </BbSelect>
                                <div class="relative">
                                    <BbButton Variant="@(_hasDetailFilter? ButtonVariant.Default: ButtonVariant.Outline)"
                                              Size="ButtonSize.Small" Class="h-8 px-2 gap-1"
                                              OnClick="() => _detailFilterOpen = !_detailFilterOpen">
                                        <LucideIcon Name="sliders-horizontal" Size="14" />
                                    </BbButton>
                                    @if (_detailFilterOpen)
                                    {
                                        <div class="absolute right-0 top-full mt-1 z-50 w-52
                                            rounded-md border bg-popover shadow-md p-3 space-y-3">
                                            <div class="space-y-1">
                                                <p class="text-xs font-medium">@L["Specialization"]</p>
                                                <BbSelect TValue="MachineSpecialization?" Value="@_filterSpec"
                                                          ValueChanged="SetDetailFilterSpec" Class="w-full">
                                                    <BbSelectTrigger Class="h-8 text-xs w-full">
                                                        <BbSelectValue Placeholder="@L["All"]" />
                                                    </BbSelectTrigger>
                                                    <BbSelectContent>
                                                        <BbSelectItem Value="@((MachineSpecialization?)null)" Text="@L["All"]">@L["All"]</BbSelectItem>
                                                        @foreach (var s in Enum.GetValues<MachineSpecialization>())
                                                        {
                                                            <BbSelectItem Value="@((MachineSpecialization?)s)" Text="@L[s.ToString()]">@L[s.ToString()]</BbSelectItem>
                                                        }
                                                    </BbSelectContent>
                                                </BbSelect>
                                            </div>
                                            <div class="space-y-1">
                                                <p class="text-xs font-medium">@L["TargetType"]</p>
                                                <BbSelect TValue="MachineTargetType?" Value="@_filterTarget"
                                                          ValueChanged="SetDetailFilterTarget" Class="w-full">
                                                    <BbSelectTrigger Class="h-8 text-xs w-full">
                                                        <BbSelectValue Placeholder="@L["All"]" />
                                                    </BbSelectTrigger>
                                                    <BbSelectContent>
                                                        <BbSelectItem Value="@((MachineTargetType?)null)" Text="@L["All"]">@L["All"]</BbSelectItem>
                                                        @foreach (var t in Enum.GetValues<MachineTargetType>())
                                                        {
                                                            <BbSelectItem Value="@((MachineTargetType?)t)" Text="@L[t.ToString()]">@L[t.ToString()]</BbSelectItem>
                                                        }
                                                    </BbSelectContent>
                                                </BbSelect>
                                            </div>
                                            <button class="text-xs text-muted-foreground hover:text-foreground"
                                                    @onclick="ClearDetailFilters">
                                                @L["ClearFilters"]
                                            </button>
                                        </div>
                                        <div class="fixed inset-0 z-40" @onclick="() => _detailFilterOpen = false"></div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="overflow-y-auto" style="max-height: 480px;">
                            @foreach (var m in _detailMachines)
                            {
                                var mStatic = StaticOf(m);
                                if (mStatic is null) continue;
                                <button class="@MachineItemClass(m)" @onclick="() => _selected = m">
                                    <picture>
                                        <source type="image/jxl" srcset="@($"{mStatic.Image}.jxl")" />
                                        <source type="image/avif" srcset="@($"{mStatic.Image}.avif")" />
                                        <source type="image/webp" srcset="@($"{mStatic.Image}.webp")" />
                                        <img src="@($"{mStatic.Image}.png")" alt="@L[mStatic.Name]"
                                             class="w-10 h-10 object-scale-down rounded shrink-0" />
                                    </picture>
                                    <div class="flex-1 min-w-0 text-left">
                                        <p class="text-sm font-medium truncate">@L[mStatic.Name]</p>
                                        <p class="text-xs text-muted-foreground truncate">
                                            @L["LevelShort"]@m.Level · @L[m.Rarity.ToString()]
                                        </p>
                                    </div>
                                    @if (IsConfigured(m))
                                    {
                                        <LucideIcon Name="circle-check" Size="16" Class="text-green-500 shrink-0" />
                                    }
                                    else
                                    {
                                        <LucideIcon Name="circle" Size="16" Class="text-muted-foreground shrink-0" />
                                    }
                                </button>
                            }
                        </div>
                    </BbCardContent>
                </BbCard>
            </div>
            <div class="lg:col-span-2">
                @if (_selected is not null)
                {
                    <MachineDetailCard Machine="_selected" OnChanged="OnChanged" />
                }
                else
                {
                    <BbCard>
                        <BbCardContent Class="flex items-center justify-center py-24">
                            <p class="text-muted-foreground text-sm">@L["SelectMachineToEdit"]</p>
                        </BbCardContent>
                    </BbCard>
                }
            </div>
        </div>
    }
    else
    {
        <BbCard>
            <BbCardContent Class="p-0">
                <div class="flex items-center gap-2 p-3 border-b flex-wrap">
                    <BbInput Placeholder="@L["Search"]" Value="@_bulkSearch" class="flex-1 min-w-40"
                             @oninput="e => SetBulkSearch(e.Value?.ToString() ?? string.Empty)" />
                    <div class="relative">
                        <BbButton Variant="@(_hasBulkFilter? ButtonVariant.Default: ButtonVariant.Outline)"
                                  Size="ButtonSize.Small" Class="h-9 px-3 gap-1.5"
                                  OnClick="() => _bulkFilterOpen = !_bulkFilterOpen">
                            <LucideIcon Name="sliders-horizontal" Size="14" />
                            <span class="text-xs">@L["Filters"]</span>
                        </BbButton>
                        @if (_bulkFilterOpen)
                        {
                            <div class="absolute right-0 top-full mt-1 z-50 w-52
                                rounded-md border bg-popover shadow-md p-3 space-y-3">
                                <div class="space-y-1">
                                    <p class="text-xs font-medium">@L["Specialization"]</p>
                                    <BbSelect TValue="MachineSpecialization?" Value="@_bulkFilterSpec"
                                              ValueChanged="SetBulkFilterSpec" Class="w-full">
                                        <BbSelectTrigger Class="h-8 text-xs w-full">
                                            <BbSelectValue Placeholder="@L["All"]" />
                                        </BbSelectTrigger>
                                        <BbSelectContent>
                                            <BbSelectItem Value="@((MachineSpecialization?)null)" Text="@L["All"]">@L["All"]</BbSelectItem>
                                            @foreach (var s in Enum.GetValues<MachineSpecialization>())
                                            {
                                                <BbSelectItem Value="@((MachineSpecialization?)s)" Text="@L[s.ToString()]">@L[s.ToString()]</BbSelectItem>
                                            }
                                        </BbSelectContent>
                                    </BbSelect>
                                </div>
                                <div class="space-y-1">
                                    <p class="text-xs font-medium">@L["TargetType"]</p>
                                    <BbSelect TValue="MachineTargetType?" Value="@_bulkFilterTarget"
                                              ValueChanged="SetBulkFilterTarget" Class="w-full">
                                        <BbSelectTrigger Class="h-8 text-xs w-full">
                                            <BbSelectValue Placeholder="@L["All"]" />
                                        </BbSelectTrigger>
                                        <BbSelectContent>
                                            <BbSelectItem Value="@((MachineTargetType?)null)" Text="@L["All"]">@L["All"]</BbSelectItem>
                                            @foreach (var t in Enum.GetValues<MachineTargetType>())
                                            {
                                                <BbSelectItem Value="@((MachineTargetType?)t)" Text="@L[t.ToString()]">@L[t.ToString()]</BbSelectItem>
                                            }
                                        </BbSelectContent>
                                    </BbSelect>
                                </div>
                                <button class="text-xs text-muted-foreground hover:text-foreground"
                                        @onclick="ClearBulkFilters">
                                    @L["ClearFilters"]
                                </button>
                            </div>
                            <div class="fixed inset-0 z-40" @onclick="() => _bulkFilterOpen = false"></div>
                        }
                    </div>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="border-b bg-muted/50">
                            <tr>
                                <th class="px-3 py-2 text-left w-44">
                                    <button class="flex items-center gap-1 font-medium text-muted-foreground hover:text-foreground transition-colors"
                                            @onclick="() => ToggleBulkSort(SortOptionsMachine.NameAtoZ, SortOptionsMachine.NameZtoA)">
                                        @L["Machine"] @ColIcon(SortOptionsMachine.NameAtoZ, SortOptionsMachine.NameZtoA)
                                    </button>
                                </th>
                                <th class="px-3 py-2 text-left w-36">
                                    <button class="flex items-center gap-1 font-medium hover:text-foreground transition-colors"
                                            @onclick="() => ToggleBulkSort(SortOptionsMachine.RarityHighToLow, SortOptionsMachine.RarityLowToHigh)">
                                        @L["Rarity"] @ColIcon(SortOptionsMachine.RarityHighToLow, SortOptionsMachine.RarityLowToHigh)
                                    </button>
                                </th>
                                <th class="px-3 py-2 text-left w-24">
                                    <button class="flex items-center gap-1 font-medium text-muted-foreground hover:text-foreground transition-colors"
                                            @onclick="() => ToggleBulkSort(SortOptionsMachine.LevelHighToLow, SortOptionsMachine.LevelLowToHigh)">
                                        @L["Level"] @ColIcon(SortOptionsMachine.LevelHighToLow, SortOptionsMachine.LevelLowToHigh)
                                    </button>
                                </th>
                                <th class="px-3 py-2 text-left w-24">
                                    <button class="flex items-center gap-1 font-medium text-muted-foreground hover:text-foreground transition-colors"
                                            @onclick="() => ToggleBulkSort(SortOptionsMachine.DamageBPHighToLow, SortOptionsMachine.DamageBPLowToHigh)">
                                        @L["BP_Damage"] @ColIcon(SortOptionsMachine.DamageBPHighToLow, SortOptionsMachine.DamageBPLowToHigh)
                                    </button>
                                </th>
                                <th class="px-3 py-2 text-left w-24">
                                    <button class="flex items-center gap-1 font-medium text-muted-foreground hover:text-foreground transition-colors"
                                            @onclick="() => ToggleBulkSort(SortOptionsMachine.HealthBPHighToLow, SortOptionsMachine.HealthBPLowToHigh)">
                                        @L["BP_Health"] @ColIcon(SortOptionsMachine.HealthBPHighToLow, SortOptionsMachine.HealthBPLowToHigh)
                                    </button>
                                </th>
                                <th class="px-3 py-2 text-left w-24">
                                    <button class="flex items-center gap-1 font-medium text-muted-foreground hover:text-foreground transition-colors"
                                            @onclick="() => ToggleBulkSort(SortOptionsMachine.ArmorBPHighToLow, SortOptionsMachine.ArmorBPLowToHigh)">
                                        @L["BP_Armor"] @ColIcon(SortOptionsMachine.ArmorBPHighToLow, SortOptionsMachine.ArmorBPLowToHigh)
                                    </button>
                                </th>
                                <th class="px-3 py-2 w-8" title="@L["Configured"]">
                                    <button class="flex items-center gap-1 font-medium text-muted-foreground hover:text-foreground transition-colors"
                                            @onclick="() => ToggleBulkSort(SortOptionsMachine.ConfiguredFirst, SortOptionsMachine.UnconfiguredFirst)">
                                        @ColIcon(SortOptionsMachine.ConfiguredFirst, SortOptionsMachine.UnconfiguredFirst)
                                    </button>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in _bulkMachines)
                            {
                                var mStatic = StaticOf(m);
                                if (mStatic is null) continue;
                                <tr class="border-b last:border-b-0 hover:bg-muted/20 transition-colors">
                                    <td class="px-3 py-2">
                                        <div class="flex items-center gap-2">
                                            <picture>
                                                <source type="image/jxl" srcset="@($"{mStatic.Image}.jxl")" />
                                                <source type="image/avif" srcset="@($"{mStatic.Image}.avif")" />
                                                <source type="image/webp" srcset="@($"{mStatic.Image}.webp")" />
                                                <img src="@($"{mStatic.Image}.png")" alt="@L[mStatic.Name]"
                                                     class="w-8 h-8 object-scale-down rounded shrink-0" />
                                            </picture>
                                            <span class="font-medium truncate">@L[mStatic.Name]</span>
                                        </div>
                                    </td>
                                    <td class="px-3 py-2">
                                        <BbSelect TValue="MachineRarity" Value="@m.Rarity"
                                                  ValueChanged="async v => { m.Rarity = v; await OnChanged.InvokeAsync(); }"
                                                  Class="w-full">
                                            <BbSelectTrigger Class="h-8 text-xs w-full">
                                                <BbSelectValue />
                                            </BbSelectTrigger>
                                            <BbSelectContent>
                                                @foreach (var r in Enum.GetValues<MachineRarity>())
                                                {
                                                    var maxRarity = GetMaxRarity(m.Level);
                                                    var isDisabled = r > maxRarity;

                                                    <BbSelectItem Value="@r"
                                                                  Disabled="@isDisabled"
                                                                  Text="@(isDisabled
                                                                                                ? $"{L[r.ToString()]} ( Level ≥ {GetRequiredLevel(r)} )"
                                                                                                : L[r.ToString()])">
                                                        @(isDisabled
                                                            ? $"{L[r.ToString()]} ( Level ≥ {GetRequiredLevel(r)} )"
                                                            : L[r.ToString()])
                                                    </BbSelectItem>
                                                }
                                            </BbSelectContent>
                                        </BbSelect>
                                    </td>
                                    <td class="px-3 py-2">
                                        <BbNumericInput TValue="int" Min="0" Step="1" AllowNegative="false"
                                                        ShowButtons="false" Value="@m.Level"
                                                        ValueChanged="async v => { m.Level = v; await OnChanged.InvokeAsync(); }"
                                                        DebounceInterval="500" Class="w-full h-8 text-xs" />
                                    </td>
                                    <td class="px-3 py-2">
                                        <BbNumericInput TValue="int" Min="0" Max="GetMaxBlueprint(m.Level)" Step="1" AllowNegative="false"
                                                        ShowButtons="false" Value="@m.DamageBlueprint"
                                                        ValueChanged="async v => { m.DamageBlueprint = v; await OnChanged.InvokeAsync(); }"
                                                        DebounceInterval="500" Class="w-full h-8 text-xs" />
                                    </td>
                                    <td class="px-3 py-2">
                                        <BbNumericInput TValue="int" Min="0" Max="GetMaxBlueprint(m.Level)" Step="1" AllowNegative="false"
                                                        ShowButtons="false" Value="@m.HealthBlueprint"
                                                        ValueChanged="async v => { m.HealthBlueprint = v; await OnChanged.InvokeAsync(); }"
                                                        DebounceInterval="500" Class="w-full h-8 text-xs" />
                                    </td>
                                    <td class="px-3 py-2">
                                        <BbNumericInput TValue="int" Min="0" Max="GetMaxBlueprint(m.Level)" Step="1" AllowNegative="false"
                                                        ShowButtons="false" Value="@m.ArmorBlueprint"
                                                        ValueChanged="async v => { m.ArmorBlueprint = v; await OnChanged.InvokeAsync(); }"
                                                        DebounceInterval="500" Class="w-full h-8 text-xs" />
                                    </td>
                                    <td class="px-3 py-2 text-center">
                                        @if (IsConfigured(m))
                                        {
                                            <LucideIcon Name="circle-check" Size="16" Class="text-green-500" />
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </BbCardContent>
        </BbCard>

        <div>
            <BbCard Class="rounded-lg bg-muted/50 border p-3">
                <p class="text-sm text-muted-foreground">                        
                    @L["BlueprintLevelFormulaExplanation"]
                </p>
            </BbCard>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public OptimizerData Data { get; set; } = null!;
    [Parameter, EditorRequired] public EventCallback OnChanged { get; set; }

    // ── View state ────────────────────────────────────────────────────────────

    private string _viewMode = "detail";
    private Machine? _selected;

    // Detail view
    private string _search = string.Empty;
    private SortOptionsMachine _detailSort = SortOptionsMachine.Default;
    private MachineSpecialization? _filterSpec;
    private MachineTargetType? _filterTarget;
    private bool _detailFilterOpen;

    // Bulk view
    private string _bulkSearch = string.Empty;
    private SortOptionsMachine _bulkSort = SortOptionsMachine.Default;
    private MachineSpecialization? _bulkFilterSpec;
    private MachineTargetType? _bulkFilterTarget;
    private bool _bulkFilterOpen;

    // ── Cached lists ──────────────────────────────────────────────────────────

    private List<Machine> _detailMachines = [];
    private List<Machine> _bulkMachines = [];

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override void OnParametersSet()
    {
        _selected = _selected is null
            ? Data.Machines.FirstOrDefault()
            : Data.Machines.FirstOrDefault(m => m.Id == _selected.Id)
              ?? Data.Machines.FirstOrDefault();

        RefreshLists();
    }

    // ── State mutators — each calls RefreshLists() ────────────────────────────

    private void SetSearch(string value) { _search = value; RefreshLists(); }
    private void SetBulkSearch(string value) { _bulkSearch = value; RefreshLists(); }
    private void SetDetailSort(SortOptionsMachine v) { _detailSort = v; RefreshLists(); }
    private void SetDetailFilterSpec(MachineSpecialization? v) { _filterSpec = v; RefreshLists(); }
    private void SetDetailFilterTarget(MachineTargetType? v) { _filterTarget = v; RefreshLists(); }
    private void SetBulkFilterSpec(MachineSpecialization? v) { _bulkFilterSpec = v; RefreshLists(); }
    private void SetBulkFilterTarget(MachineTargetType? v) { _bulkFilterTarget = v; RefreshLists(); }

    private void ClearDetailFilters()
    {
        _filterSpec = null;
        _filterTarget = null;
        RefreshLists();
    }

    private void ClearBulkFilters()
    {
        _bulkFilterSpec = null;
        _bulkFilterTarget = null;
        RefreshLists();
    }

    private void ToggleBulkSort(SortOptionsMachine asc, SortOptionsMachine desc)
    {
        _bulkSort = _bulkSort == asc ? desc : asc;
        RefreshLists();
    }

    // ── List computation ──────────────────────────────────────────────────────

    private void RefreshLists()
    {
        _detailMachines = Sort(Filter(Data.Machines, _search, _filterSpec, _filterTarget), _detailSort);
        _bulkMachines = Sort(Filter(Data.Machines, _bulkSearch, _bulkFilterSpec, _bulkFilterTarget), _bulkSort);
    }

    private List<Machine> Filter(
        IEnumerable<Machine> source,
        string search,
        MachineSpecialization? spec,
        MachineTargetType? target)
    {
        if (!string.IsNullOrWhiteSpace(search))
            source = source.Where(m => NameOf(m).Contains(search, StringComparison.OrdinalIgnoreCase));

        if (spec is not null)
            source = source.Where(m => StaticOf(m)?.Specialization == spec);

        if (target is not null)
            source = source.Where(m => StaticOf(m)?.TargetType == target);

        return source.ToList();
    }

    private List<Machine> Sort(List<Machine> source, SortOptionsMachine sort)
    {
        if (sort is SortOptionsMachine.NameAtoZ or SortOptionsMachine.NameZtoA)
        {
            var names = source.ToDictionary(m => m.Id, m => L[NameOf(m)].Value);
            return sort == SortOptionsMachine.NameAtoZ
                ? [.. source.OrderBy(m => names[m.Id], StringComparer.CurrentCulture)]
                : [.. source.OrderByDescending(m => names[m.Id], StringComparer.CurrentCulture)];
        }

        return sort switch
        {
            SortOptionsMachine.Default => source,
            SortOptionsMachine.LevelHighToLow => [.. source.OrderByDescending(m => m.Level)],
            SortOptionsMachine.LevelLowToHigh => [.. source.OrderBy(m => m.Level)],
            SortOptionsMachine.RarityHighToLow => [.. source.OrderByDescending(m => (int)m.Rarity)],
            SortOptionsMachine.RarityLowToHigh => [.. source.OrderBy(m => (int)m.Rarity)],
            SortOptionsMachine.DamageBPHighToLow => [.. source.OrderByDescending(m => m.DamageBlueprint)],
            SortOptionsMachine.DamageBPLowToHigh => [.. source.OrderBy(m => m.DamageBlueprint)],
            SortOptionsMachine.HealthBPHighToLow => [.. source.OrderByDescending(m => m.HealthBlueprint)],
            SortOptionsMachine.HealthBPLowToHigh => [.. source.OrderBy(m => m.HealthBlueprint)],
            SortOptionsMachine.ArmorBPHighToLow => [.. source.OrderByDescending(m => m.ArmorBlueprint)],
            SortOptionsMachine.ArmorBPLowToHigh => [.. source.OrderBy(m => m.ArmorBlueprint)],
            SortOptionsMachine.ConfiguredFirst => [.. source.OrderByDescending(IsConfigured)],
            SortOptionsMachine.UnconfiguredFirst => [.. source.OrderBy(IsConfigured)],
            _ => [.. source.OrderBy(m => m.Id)],
        };
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static bool IsConfigured(Machine m) =>
        m.Level > 0 || m.DamageBlueprint > 0 || m.HealthBlueprint > 0 ||
        m.ArmorBlueprint > 0 || m.Rarity is not MachineRarity.Common;

    private MachineStatic? StaticOf(Machine m) =>
        MachineService.Machines.FirstOrDefault(s => s.Id == m.Id);

    private string NameOf(Machine m) =>
        StaticOf(m)?.Name ?? string.Empty;

    private bool _hasDetailFilter => _filterSpec is not null || _filterTarget is not null;
    private bool _hasBulkFilter => _bulkFilterSpec is not null || _bulkFilterTarget is not null;

    private string MachineItemClass(Machine m) =>
        m == _selected
            ? "flex items-center gap-3 w-full px-3 py-2 bg-accent text-accent-foreground"
            : "flex items-center gap-3 w-full px-3 py-2 hover:bg-accent/50 transition-colors";

    private RenderFragment ColIcon(SortOptionsMachine asc, SortOptionsMachine desc) => __builder =>
    {
        bool active = _bulkSort == asc || _bulkSort == desc;
        bool isAsc = _bulkSort == asc;

        if (!active)
        {
            <svg class="w-3 h-3 opacity-30 inline" xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m7 15 5 5 5-5M7 9l5-5 5 5" />
            </svg>
        }
        else if (isAsc)
        {
            <svg class="w-3 h-3 inline" xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m18 15-6-6-6 6" />
            </svg>
        }
        else
        {
            <svg class="w-3 h-3 inline" xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6" />
            </svg>
        }
    };

    private int GetMaxBlueprint(int level)
    {
        return 5 + (level / 5 * 5);
    }

    private MachineRarity GetMaxRarity(int level)
    {
        switch (level)
        {
            case >= 500:
                return MachineRarity.Celestial;
            case >= 400:
                return MachineRarity.Angel;
            case >= 310:
                return MachineRarity.Titan;
            case >= 230:
                return MachineRarity.Mythic;
            case >= 160:
                return MachineRarity.Legendary;
            case >= 100:
                return MachineRarity.Epic;
            case >= 50:
                return MachineRarity.Rare;
            case >= 10:
                return MachineRarity.Uncommon;
            default:
                return MachineRarity.Common;
        }
    }

    private int GetRequiredLevel(MachineRarity rarity)
    {
        return rarity switch
        {
            MachineRarity.Celestial => 500,
            MachineRarity.Angel => 400,
            MachineRarity.Titan => 310,
            MachineRarity.Mythic => 230,
            MachineRarity.Legendary => 160,
            MachineRarity.Epic => 100,
            MachineRarity.Rare => 50,
            MachineRarity.Uncommon => 10,
            _ => 0
        };
    }
}
