@using InfatalsFirestoneTools.Models
@using InfatalsFirestoneTools.Services
@using InfatalsFirestoneTools.Resources
@inject HeroService HeroService
@inject IStringLocalizer<LanguageResource> L

<div class="space-y-4">

    <div class="flex items-center gap-1 rounded-lg border bg-muted p-1 w-fit">
        <BbToggleGroup TValue="string" @bind-Value="_viewMode" Type="ToggleGroupType.Single">
            <BbToggleGroupItem Value="@("detail")">
                <LucideIcon Name="layout-panel-left" Size="14" Class="mr-1.5" />
                @L["Detail"]
            </BbToggleGroupItem>
            <BbToggleGroupItem Value="@("bulk")">
                <LucideIcon Name="table" Size="14" Class="mr-1.5" />
                @L["BulkEdit"]
            </BbToggleGroupItem>
        </BbToggleGroup>
    </div>

    @if (_viewMode == "detail")
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 w-full">
            <div class="lg:col-span-1">
                <BbCard>
                    <BbCardHeader>
                        <BbCardTitle>@L["HeroList"]</BbCardTitle>
                    </BbCardHeader>
                    <BbCardContent Class="p-0">
                        <div class="p-3 border-b space-y-2">
                            <BbInput Placeholder="@L["Search"]" Value="@_search" class="w-full"
                                     @oninput="e => SetSearch(e.Value?.ToString() ?? string.Empty)" />
                            <div class="flex gap-2">
                                <BbSelect TValue="SortOptionsHero" Value="@_detailSort"
                                          ValueChanged="SetDetailSort" Class="flex-1">
                                    <BbSelectTrigger Class="h-8 text-xs flex-1">
                                        <BbSelectValue Placeholder="@L["SortBy"]" />
                                    </BbSelectTrigger>
                                    <BbSelectContent>
                                        @foreach (var opt in Enum.GetValues<SortOptionsHero>())
                                        {
                                            <BbSelectItem Value="@opt" Text="@L[opt.ToString()]">@L[opt.ToString()]</BbSelectItem>
                                        }
                                    </BbSelectContent>
                                </BbSelect>
                                <div class="relative">
                                    <BbButton Variant="@(_hasDetailFilter? ButtonVariant.Default: ButtonVariant.Outline)"
                                              Size="ButtonSize.Small" Class="h-8 px-2 gap-1"
                                              OnClick="() => _detailFilterOpen = !_detailFilterOpen">
                                        <LucideIcon Name="sliders-horizontal" Size="14" />
                                    </BbButton>
                                    @if (_detailFilterOpen)
                                    {
                                        <div class="absolute right-0 top-full mt-1 z-50 w-56
                                            rounded-md border bg-popover shadow-md p-3 space-y-3">
                                            <div class="space-y-1">
                                                <p class="text-xs font-medium">@L["Type"]</p>
                                                <BbSelect TValue="HeroType?" Value="@_filterType"
                                                          ValueChanged="SetDetailFilterType" Class="w-full">
                                                    <BbSelectTrigger Class="h-8 text-xs w-full">
                                                        <BbSelectValue Placeholder="@L["All"]" />
                                                    </BbSelectTrigger>
                                                    <BbSelectContent>
                                                        <BbSelectItem Value="@((HeroType?)null)" Text="@L["All"]">@L["All"]</BbSelectItem>
                                                        @foreach (var t in Enum.GetValues<HeroType>())
                                                        {
                                                            <BbSelectItem Value="@((HeroType?)t)" Text="@L[t.ToString()]">@L[t.ToString()]</BbSelectItem>
                                                        }
                                                    </BbSelectContent>
                                                </BbSelect>
                                            </div>
                                            <div class="space-y-1">
                                                <p class="text-xs font-medium">@L["Class"]</p>
                                                <BbSelect TValue="HeroClass?" Value="@_filterClass"
                                                          ValueChanged="SetDetailFilterClass" Class="w-full">
                                                    <BbSelectTrigger Class="h-8 text-xs w-full">
                                                        <BbSelectValue Placeholder="@L["All"]" />
                                                    </BbSelectTrigger>
                                                    <BbSelectContent>
                                                        <BbSelectItem Value="@((HeroClass?)null)" Text="@L["All"]">@L["All"]</BbSelectItem>
                                                        @foreach (var c in Enum.GetValues<HeroClass>())
                                                        {
                                                            <BbSelectItem Value="@((HeroClass?)c)" Text="@L[c.ToString()]">@L[c.ToString()]</BbSelectItem>
                                                        }
                                                    </BbSelectContent>
                                                </BbSelect>
                                            </div>
                                            <div class="space-y-1">
                                                <p class="text-xs font-medium">@L["AttackStyle"]</p>
                                                <BbSelect TValue="HeroAttackStyle?" Value="@_filterAttackStyle"
                                                          ValueChanged="SetDetailFilterAttackStyle" Class="w-full">
                                                    <BbSelectTrigger Class="h-8 text-xs w-full">
                                                        <BbSelectValue Placeholder="@L["All"]" />
                                                    </BbSelectTrigger>
                                                    <BbSelectContent>
                                                        <BbSelectItem Value="@((HeroAttackStyle?)null)" Text="@L["All"]">@L["All"]</BbSelectItem>
                                                        @foreach (var a in Enum.GetValues<HeroAttackStyle>())
                                                        {
                                                            <BbSelectItem Value="@((HeroAttackStyle?)a)" Text="@L[a.ToString()]">@L[a.ToString()]</BbSelectItem>
                                                        }
                                                    </BbSelectContent>
                                                </BbSelect>
                                            </div>
                                            <div class="space-y-1">
                                                <p class="text-xs font-medium">@L["Specialization"]</p>
                                                <BbSelect TValue="HeroSpecialization?" Value="@_filterSpec"
                                                          ValueChanged="SetDetailFilterSpec" Class="w-full">
                                                    <BbSelectTrigger Class="h-8 text-xs w-full">
                                                        <BbSelectValue Placeholder="@L["All"]" />
                                                    </BbSelectTrigger>
                                                    <BbSelectContent>
                                                        <BbSelectItem Value="@((HeroSpecialization?)null)" Text="@L["All"]">@L["All"]</BbSelectItem>
                                                        @foreach (var s in Enum.GetValues<HeroSpecialization>())
                                                        {
                                                            <BbSelectItem Value="@((HeroSpecialization?)s)" Text="@L[s.ToString()]">@L[s.ToString()]</BbSelectItem>
                                                        }
                                                    </BbSelectContent>
                                                </BbSelect>
                                            </div>
                                            <div class="space-y-1">
                                                <p class="text-xs font-medium">@L["Resource"]</p>
                                                <BbSelect TValue="HeroResource?" Value="@_filterResource"
                                                          ValueChanged="SetDetailFilterResource" Class="w-full">
                                                    <BbSelectTrigger Class="h-8 text-xs w-full">
                                                        <BbSelectValue Placeholder="@L["All"]" />
                                                    </BbSelectTrigger>
                                                    <BbSelectContent>
                                                        <BbSelectItem Value="@((HeroResource?)null)" Text="@L["All"]">@L["All"]</BbSelectItem>
                                                        @foreach (var r in Enum.GetValues<HeroResource>())
                                                        {
                                                            <BbSelectItem Value="@((HeroResource?)r)" Text="@L[r.ToString()]">@L[r.ToString()]</BbSelectItem>
                                                        }
                                                    </BbSelectContent>
                                                </BbSelect>
                                            </div>
                                            <button class="text-xs text-muted-foreground hover:text-foreground"
                                                    @onclick="ClearDetailFilters">
                                                @L["ClearFilters"]
                                            </button>
                                        </div>
                                        <div class="fixed inset-0 z-40" @onclick="() => _detailFilterOpen = false"></div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="overflow-y-auto" style="max-height: 480px;">
                            @foreach (var h in _detailHeroes)
                            {
                                var hStatic = StaticOf(h);
                                if (hStatic is null) continue;
                                <button class="@HeroItemClass(h)" @onclick="() => _selected = h">
                                    <picture>
                                        <source type="image/jxl" srcset="@($"{hStatic.Image}.jxl")" />
                                        <source type="image/avif" srcset="@($"{hStatic.Image}.avif")" />
                                        <source type="image/webp" srcset="@($"{hStatic.Image}.webp")" />
                                        <img src="@($"{hStatic.Image}.png")" alt="@L[hStatic.Name]"
                                             class="w-10 h-10 object-scale-down rounded shrink-0" />
                                    </picture>
                                    <div class="flex-1 min-w-0 text-left">
                                        <p class="text-sm font-medium truncate">@L[hStatic.Name]</p>
                                        <p class="text-xs text-muted-foreground truncate">
                                            @L[hStatic.Specialization.ToString()] · @L[hStatic.Class.ToString()]
                                        </p>
                                    </div>
                                    @if (IsConfigured(h))
                                    {
                                        <LucideIcon Name="circle-check" Size="16" Class="text-green-500 shrink-0" />
                                    }
                                    else
                                    {
                                        <LucideIcon Name="circle" Size="16" Class="text-muted-foreground shrink-0" />
                                    }
                                </button>
                            }
                        </div>
                    </BbCardContent>
                </BbCard>
            </div>
            <div class="lg:col-span-2">
                @if (_selected is not null)
                {
                    <HeroDetailCard Hero="_selected" OnChanged="OnChanged" />
                }
                else
                {
                    <BbCard>
                        <BbCardContent Class="flex items-center justify-center py-24">
                            <p class="text-muted-foreground text-sm">@L["SelectAHeroToEdit"]</p>
                        </BbCardContent>
                    </BbCard>
                }
            </div>
        </div>
    }
    else
    {
        <BbCard>
            <BbCardContent Class="p-0">
                <div class="flex items-center gap-2 p-3 border-b flex-wrap">
                    <BbInput Placeholder="@L["Search"]" Value="@_bulkSearch" class="flex-1 min-w-40"
                             @oninput="e => SetBulkSearch(e.Value?.ToString() ?? string.Empty)" />
                    <div class="relative">
                        <BbButton Variant="@(_hasBulkFilter? ButtonVariant.Default: ButtonVariant.Outline)"
                                  Size="ButtonSize.Small" Class="h-9 px-3 gap-1.5"
                                  OnClick="() => _bulkFilterOpen = !_bulkFilterOpen">
                            <LucideIcon Name="sliders-horizontal" Size="14" />
                            <span class="text-xs">@L["Filters"]</span>
                        </BbButton>
                        @if (_bulkFilterOpen)
                        {
                            <div class="absolute right-0 top-full mt-1 z-50 w-56
                                rounded-md border bg-popover shadow-md p-3 space-y-3">
                                <div class="space-y-1">
                                    <p class="text-xs font-medium">@L["Type"]</p>
                                    <BbSelect TValue="HeroType?" Value="@_bulkFilterType"
                                              ValueChanged="SetBulkFilterType" Class="w-full">
                                        <BbSelectTrigger Class="h-8 text-xs w-full">
                                            <BbSelectValue Placeholder="@L["All"]" />
                                        </BbSelectTrigger>
                                        <BbSelectContent>
                                            <BbSelectItem Value="@((HeroType?)null)">@L["All"]</BbSelectItem>
                                            @foreach (var t in Enum.GetValues<HeroType>())
                                            {
                                                <BbSelectItem Value="@((HeroType?)t)" Text="@L[t.ToString()]">@L[t.ToString()]</BbSelectItem>
                                            }
                                        </BbSelectContent>
                                    </BbSelect>
                                </div>
                                <div class="space-y-1">
                                    <p class="text-xs font-medium">@L["Class"]</p>
                                    <BbSelect TValue="HeroClass?" Value="@_bulkFilterClass"
                                              ValueChanged="SetBulkFilterClass" Class="w-full">
                                        <BbSelectTrigger Class="h-8 text-xs w-full">
                                            <BbSelectValue Placeholder="@L["All"]" />
                                        </BbSelectTrigger>
                                        <BbSelectContent>
                                            <BbSelectItem Value="@((HeroClass?)null)">@L["All"]</BbSelectItem>
                                            @foreach (var c in Enum.GetValues<HeroClass>())
                                            {
                                                <BbSelectItem Value="@((HeroClass?)c)" Text="@L[c.ToString()]">@L[c.ToString()]</BbSelectItem>
                                            }
                                        </BbSelectContent>
                                    </BbSelect>
                                </div>
                                <div class="space-y-1">
                                    <p class="text-xs font-medium">@L["AttackStyle"]</p>
                                    <BbSelect TValue="HeroAttackStyle?" Value="@_bulkFilterAttackStyle"
                                              ValueChanged="SetBulkFilterAttackStyle" Class="w-full">
                                        <BbSelectTrigger Class="h-8 text-xs w-full">
                                            <BbSelectValue Placeholder="@L["All"]" />
                                        </BbSelectTrigger>
                                        <BbSelectContent>
                                            <BbSelectItem Value="@((HeroAttackStyle?)null)">@L["All"]</BbSelectItem>
                                            @foreach (var a in Enum.GetValues<HeroAttackStyle>())
                                            {
                                                <BbSelectItem Value="@((HeroAttackStyle?)a)" Text="@L[a.ToString()]">@L[a.ToString()]</BbSelectItem>
                                            }
                                        </BbSelectContent>
                                    </BbSelect>
                                </div>
                                <div class="space-y-1">
                                    <p class="text-xs font-medium">@L["Specialization"]</p>
                                    <BbSelect TValue="HeroSpecialization?" Value="@_bulkFilterSpec"
                                              ValueChanged="SetBulkFilterSpec" Class="w-full">
                                        <BbSelectTrigger Class="h-8 text-xs w-full">
                                            <BbSelectValue Placeholder="@L["All"]" />
                                        </BbSelectTrigger>
                                        <BbSelectContent>
                                            <BbSelectItem Value="@((HeroSpecialization?)null)">@L["All"]</BbSelectItem>
                                            @foreach (var s in Enum.GetValues<HeroSpecialization>())
                                            {
                                                <BbSelectItem Value="@((HeroSpecialization?)s)" Text="@L[s.ToString()]">@L[s.ToString()]</BbSelectItem>
                                            }
                                        </BbSelectContent>
                                    </BbSelect>
                                </div>
                                <div class="space-y-1">
                                    <p class="text-xs font-medium">@L["Resource"]</p>
                                    <BbSelect TValue="HeroResource?" Value="@_bulkFilterResource"
                                              ValueChanged="SetBulkFilterResource" Class="w-full">
                                        <BbSelectTrigger Class="h-8 text-xs w-full">
                                            <BbSelectValue Placeholder="@L["All"]" />
                                        </BbSelectTrigger>
                                        <BbSelectContent>
                                            <BbSelectItem Value="@((HeroResource?)null)">@L["All"]</BbSelectItem>
                                            @foreach (var r in Enum.GetValues<HeroResource>())
                                            {
                                                <BbSelectItem Value="@((HeroResource?)r)" Text="@L[r.ToString()]">@L[r.ToString()]</BbSelectItem>
                                            }
                                        </BbSelectContent>
                                    </BbSelect>
                                </div>
                                <button class="text-xs text-muted-foreground hover:text-foreground"
                                        @onclick="ClearBulkFilters">
                                    @L["ClearFilters"]
                                </button>
                            </div>
                            <div class="fixed inset-0 z-40" @onclick="() => _bulkFilterOpen = false"></div>
                        }
                    </div>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="border-b bg-muted/50">
                            <tr>
                                <th class="px-3 py-2 text-left w-56">
                                    <button class="flex items-center gap-1 font-medium text-muted-foreground hover:text-foreground transition-colors"
                                            @onclick="() => ToggleBulkSort(SortOptionsHero.NameAtoZ, SortOptionsHero.NameZtoA)">
                                        @L["Hero"] @ColIcon(SortOptionsHero.NameAtoZ, SortOptionsHero.NameZtoA)
                                    </button>
                                </th>
                                <th class="px-3 py-2 text-left w-28">
                                    <button class="flex items-center gap-1 font-medium text-muted-foreground hover:text-foreground transition-colors"
                                            @onclick="() => ToggleBulkSort(SortOptionsHero.DamageHighToLow, SortOptionsHero.DamageLowToHigh)">
                                        @L["Damage"] % @ColIcon(SortOptionsHero.DamageHighToLow, SortOptionsHero.DamageLowToHigh)
                                    </button>
                                </th>
                                <th class="px-3 py-2 text-left w-28">
                                    <button class="flex items-center gap-1 font-medium text-muted-foreground hover:text-foreground transition-colors"
                                            @onclick="() => ToggleBulkSort(SortOptionsHero.HealthHighToLow, SortOptionsHero.HealthLowToHigh)">
                                        @L["Health"] % @ColIcon(SortOptionsHero.HealthHighToLow, SortOptionsHero.HealthLowToHigh)
                                    </button>
                                </th>
                                <th class="px-3 py-2 text-left w-28">
                                    <button class="flex items-center gap-1 font-medium text-muted-foreground hover:text-foreground transition-colors"
                                            @onclick="() => ToggleBulkSort(SortOptionsHero.ArmorHighToLow, SortOptionsHero.ArmorLowToHigh)">
                                        @L["Armor"] % @ColIcon(SortOptionsHero.ArmorHighToLow, SortOptionsHero.ArmorLowToHigh)
                                    </button>
                                </th>
                                <th class="px-3 py-2 w-8" title="@L["Configured"]">
                                    <button class="flex items-center gap-1 font-medium text-muted-foreground hover:text-foreground transition-colors"
                                            @onclick="() => ToggleBulkSort(SortOptionsHero.ConfiguredFirst, SortOptionsHero.UnconfiguredFirst)">
                                        @ColIcon(SortOptionsHero.ConfiguredFirst, SortOptionsHero.UnconfiguredFirst)
                                    </button>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in _bulkHeroes)
                            {
                                var hStatic = StaticOf(h);
                                if (hStatic is null) continue;
                                <tr class="border-b last:border-b-0 hover:bg-muted/20 transition-colors">
                                    <td class="px-3 py-2">
                                        <div class="flex items-center gap-2">
                                            <picture>
                                                <source type="image/jxl" srcset="@($"{hStatic.Image}.jxl")" />
                                                <source type="image/avif" srcset="@($"{hStatic.Image}.avif")" />
                                                <source type="image/webp" srcset="@($"{hStatic.Image}.webp")" />
                                                <img src="@($"{hStatic.Image}.png")" alt="@L[hStatic.Name]"
                                                     class="w-8 h-8 object-scale-down rounded shrink-0" />
                                            </picture>
                                            <div class="min-w-0">
                                                <p class="font-medium truncate">@L[hStatic.Name]</p>
                                                <p class="text-xs text-muted-foreground truncate">
                                                    @L[hStatic.Specialization.ToString()] · @L[hStatic.Class.ToString()]
                                                </p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-3 py-2">
                                        <BbNumericInput TValue="int" Min="0" Step="20" AllowNegative="false"
                                                        ShowButtons="false" Value="h.DamagePercentage"
                                                        ValueChanged="async v => { h.DamagePercentage = v; await OnChanged.InvokeAsync(); }"
                                                        DebounceInterval="500" Class="w-full h-8 text-xs" />
                                    </td>
                                    <td class="px-3 py-2">
                                        <BbNumericInput TValue="int" Min="0" Step="20" AllowNegative="false"
                                                        ShowButtons="false" Value="h.HealthPercentage"
                                                        ValueChanged="async v => { h.HealthPercentage = v; await OnChanged.InvokeAsync(); }"
                                                        DebounceInterval="500" Class="w-full h-8 text-xs" />
                                    </td>
                                    <td class="px-3 py-2">
                                        <BbNumericInput TValue="int" Min="0" Step="20" AllowNegative="false"
                                                        ShowButtons="false" Value="h.ArmorPercentage"
                                                        ValueChanged="async v => { h.ArmorPercentage = v; await OnChanged.InvokeAsync(); }"
                                                        DebounceInterval="500" Class="w-full h-8 text-xs" />
                                    </td>
                                    <td class="px-3 py-2 text-center">
                                        @if (IsConfigured(h))
                                        {
                                            <LucideIcon Name="circle-check" Size="16" Class="text-green-500" />
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </BbCardContent>
        </BbCard>
    }

</div>

@code {
    [Parameter, EditorRequired] public OptimizerData Data { get; set; } = null!;
    [Parameter, EditorRequired] public EventCallback OnChanged { get; set; }

    // ── View state ────────────────────────────────────────────────────────────

    private string _viewMode = "detail";
    private Hero? _selected;

    // Detail view
    private string _search = string.Empty;
    private SortOptionsHero _detailSort = SortOptionsHero.Default;
    private HeroType? _filterType;
    private HeroClass? _filterClass;
    private HeroAttackStyle? _filterAttackStyle;
    private HeroSpecialization? _filterSpec;
    private HeroResource? _filterResource;
    private bool _detailFilterOpen;

    // Bulk view
    private string _bulkSearch = string.Empty;
    private SortOptionsHero _bulkSort = SortOptionsHero.Default;
    private HeroType? _bulkFilterType;
    private HeroClass? _bulkFilterClass;
    private HeroAttackStyle? _bulkFilterAttackStyle;
    private HeroSpecialization? _bulkFilterSpec;
    private HeroResource? _bulkFilterResource;
    private bool _bulkFilterOpen;

    // ── Cached lists ──────────────────────────────────────────────────────────

    private List<Hero> _detailHeroes = [];
    private List<Hero> _bulkHeroes = [];

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override void OnParametersSet()
    {
        _selected = _selected is null
            ? Data.Heroes.FirstOrDefault()
            : Data.Heroes.FirstOrDefault(h => h.Id == _selected.Id)
              ?? Data.Heroes.FirstOrDefault();

        RefreshLists();
    }

    // ── State mutators — each calls RefreshLists() ────────────────────────────

    private void SetSearch(string value) { _search = value; RefreshLists(); }
    private void SetBulkSearch(string value) { _bulkSearch = value; RefreshLists(); }
    private void SetDetailSort(SortOptionsHero v) { _detailSort = v; RefreshLists(); }
    private void SetDetailFilterType(HeroType? v) { _filterType = v; RefreshLists(); }
    private void SetDetailFilterClass(HeroClass? v) { _filterClass = v; RefreshLists(); }
    private void SetDetailFilterAttackStyle(HeroAttackStyle? v) { _filterAttackStyle = v; RefreshLists(); }
    private void SetDetailFilterSpec(HeroSpecialization? v) { _filterSpec = v; RefreshLists(); }
    private void SetDetailFilterResource(HeroResource? v) { _filterResource = v; RefreshLists(); }
    private void SetBulkFilterType(HeroType? v) { _bulkFilterType = v; RefreshLists(); }
    private void SetBulkFilterClass(HeroClass? v) { _bulkFilterClass = v; RefreshLists(); }
    private void SetBulkFilterAttackStyle(HeroAttackStyle? v) { _bulkFilterAttackStyle = v; RefreshLists(); }
    private void SetBulkFilterSpec(HeroSpecialization? v) { _bulkFilterSpec = v; RefreshLists(); }
    private void SetBulkFilterResource(HeroResource? v) { _bulkFilterResource = v; RefreshLists(); }

    private void ClearDetailFilters()
    {
        _filterType = null; _filterClass = null; _filterAttackStyle = null;
        _filterSpec = null; _filterResource = null;
        RefreshLists();
    }

    private void ClearBulkFilters()
    {
        _bulkFilterType = null; _bulkFilterClass = null; _bulkFilterAttackStyle = null;
        _bulkFilterSpec = null; _bulkFilterResource = null;
        RefreshLists();
    }

    private void ToggleBulkSort(SortOptionsHero asc, SortOptionsHero desc)
    {
        _bulkSort = _bulkSort == asc ? desc : asc;
        RefreshLists();
    }

    // ── List computation ──────────────────────────────────────────────────────

    private void RefreshLists()
    {
        _detailHeroes = Sort(
            Filter(Data.Heroes, _search, _filterType, _filterClass, _filterAttackStyle, _filterSpec, _filterResource),
            _detailSort);

        _bulkHeroes = Sort(
            Filter(Data.Heroes, _bulkSearch, _bulkFilterType, _bulkFilterClass, _bulkFilterAttackStyle, _bulkFilterSpec, _bulkFilterResource),
            _bulkSort);
    }

    private List<Hero> Filter(
        IEnumerable<Hero> source,
        string search,
        HeroType? type,
        HeroClass? heroClass,
        HeroAttackStyle? attackStyle,
        HeroSpecialization? spec,
        HeroResource? resource)
    {
        if (!string.IsNullOrWhiteSpace(search))
            source = source.Where(h =>
                NameOf(h).Contains(search, StringComparison.OrdinalIgnoreCase) ||
                (StaticOf(h)?.Class.ToString().Contains(search, StringComparison.OrdinalIgnoreCase) ?? false));

        if (type is not null) source = source.Where(h => StaticOf(h)?.Type == type);
        if (heroClass is not null) source = source.Where(h => StaticOf(h)?.Class == heroClass);
        if (attackStyle is not null) source = source.Where(h => StaticOf(h)?.AttackStyle == attackStyle);
        if (spec is not null) source = source.Where(h => StaticOf(h)?.Specialization == spec);
        if (resource is not null) source = source.Where(h => StaticOf(h)?.Resource == resource);

        return source.ToList();
    }

    private List<Hero> Sort(List<Hero> source, SortOptionsHero sort)
    {
        if (sort is SortOptionsHero.NameAtoZ or SortOptionsHero.NameZtoA)
        {
            var names = source.ToDictionary(h => h.Id, h => L[NameOf(h)].Value);
            return sort == SortOptionsHero.NameAtoZ
                ? [.. source.OrderBy(h => names[h.Id], StringComparer.CurrentCulture)]
                : [.. source.OrderByDescending(h => names[h.Id], StringComparer.CurrentCulture)];
        }

        return sort switch
        {
            SortOptionsHero.Default => [.. source.OrderBy(h => (int)(StaticOf(h)?.Type ?? HeroType.Hero))],
            SortOptionsHero.DamageHighToLow => [.. source.OrderByDescending(h => h.DamagePercentage)],
            SortOptionsHero.DamageLowToHigh => [.. source.OrderBy(h => h.DamagePercentage)],
            SortOptionsHero.HealthHighToLow => [.. source.OrderByDescending(h => h.HealthPercentage)],
            SortOptionsHero.HealthLowToHigh => [.. source.OrderBy(h => h.HealthPercentage)],
            SortOptionsHero.ArmorHighToLow => [.. source.OrderByDescending(h => h.ArmorPercentage)],
            SortOptionsHero.ArmorLowToHigh => [.. source.OrderBy(h => h.ArmorPercentage)],
            SortOptionsHero.ConfiguredFirst => [.. source.OrderByDescending(IsConfigured)],
            SortOptionsHero.UnconfiguredFirst => [.. source.OrderBy(IsConfigured)],
            _ => [.. source.OrderBy(h => h.Id)],
        };
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static bool IsConfigured(Hero h) =>
        h.DamagePercentage > 0 || h.HealthPercentage > 0 || h.ArmorPercentage > 0;

    private HeroStatic? StaticOf(Hero h) =>
        HeroService.Heroes.FirstOrDefault(s => s.Id == h.Id);

    private string NameOf(Hero h) =>
        StaticOf(h)?.Name ?? string.Empty;

    private bool _hasDetailFilter =>
        _filterType is not null || _filterClass is not null ||
        _filterAttackStyle is not null || _filterSpec is not null ||
        _filterResource is not null;

    private bool _hasBulkFilter =>
        _bulkFilterType is not null || _bulkFilterClass is not null ||
        _bulkFilterAttackStyle is not null || _bulkFilterSpec is not null ||
        _bulkFilterResource is not null;

    private string HeroItemClass(Hero h) =>
        h == _selected
            ? "flex items-center gap-3 w-full px-3 py-2 bg-accent text-accent-foreground"
            : "flex items-center gap-3 w-full px-3 py-2 hover:bg-accent/50 transition-colors";

    private RenderFragment ColIcon(SortOptionsHero asc, SortOptionsHero desc) => __builder =>
    {
        bool active = _bulkSort == asc || _bulkSort == desc;
        bool isAsc = _bulkSort == asc;

        if (!active)
        {
            <svg class="w-3 h-3 opacity-30 inline" xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m7 15 5 5 5-5M7 9l5-5 5 5" />
            </svg>
        }
        else if (isAsc)
        {
            <svg class="w-3 h-3 inline" xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m18 15-6-6-6 6" />
            </svg>
        }
        else
        {
            <svg class="w-3 h-3 inline" xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6" />
            </svg>
        }
    };
}
